schemaVersion: 1
kind: zj-loop-route-table

metadata:
  primary_pattern: "__PATTERN_ID__"
  primary_pattern_name: "__PATTERN_NAME__"
  generated_by: "zj-loop-init"

policy:
  description: "Routing policy for loop signals. This file is not a runtime queue."
  lifecycle_evidence:
    - "append-only issue or PR comments"
    - "consumer-owned state files"
    - "workflow runs"
    - "PRs"
  default_enablement:
    human: true
    ignore: true
    selected_pattern_report_only: true
    cross_component_dispatch: false
    side_effect_routes: false

routes:
  - route_id: "human"
    enabled: true
    request_kind: "report-only"
    consumer: "maintainer"
    evidence_store: "__PATTERN_STATE__"
    match:
      risk: ["high", "unknown"]
    guards:
      requires_human_review: true
    dedupe_window: "24h"
    failure_owner: "maintainer"
    human_gate: "always"

  - route_id: "ignore"
    enabled: true
    request_kind: "report-only"
    consumer: "producer"
    evidence_store: "__PATTERN_STATE__"
    match:
      route: ["ignore"]
    guards:
      requires_noise_reason: true
    dedupe_window: "24h"
    failure_owner: "producer"
    human_gate: "none"

  - route_id: "__PATTERN_ID__-report"
    enabled: true
    request_kind: "report-only"
    consumer: "__PATTERN_ID__"
    evidence_store: "__PATTERN_STATE__"
    match:
      route: ["__PATTERN_ID__"]
    guards:
      side_effects_allowed: false
    dedupe_window: "24h"
    failure_owner: "__PATTERN_ID__"
    human_gate: "on ambiguity or high risk"

disabled_dispatch_routes:
  - route_id: "ci-sweeper"
    enabled: false
    request_kind: "workflow-dispatch"
    consumer: "ci-sweeper"
    evidence_store: "zj-loop/ci-sweeper-state.md"
    note: "Enable only after CI Sweeper workflow, budget, and failure owner are configured."

  - route_id: "dependency-sweeper"
    enabled: false
    request_kind: "evidence-request"
    consumer: "dependency-sweeper"
    evidence_store: "zj-loop/dependency-sweeper-state.md"
    note: "Enable only after dependency risk policy and verifier gates are configured."

  - route_id: "roadmap-sliced-development"
    enabled: false
    request_kind: "activation-comment"
    consumer: "roadmap-sliced-development"
    evidence_store: "append-only GitHub issue comments"
    note: "Activation creates a request only; Roadmap-Sliced Development owns execution."

  - route_id: "post-merge-roadmap-closeout"
    enabled: false
    request_kind: "report-only"
    consumer: "post-merge-cleanup"
    mode: "roadmap-closeout"
    evidence_store: "GitHub pull request comment"
    guards:
      requires_post_merge_contract: true
      report_only_if_contract_missing: true
      requires_no_pending_followups: true
      destructive_actions_enabled: false
      branch_prefix_allowlist: ["zjal/"]
      close_carrier_issue_only: true
    note: "Enable only after merged-PR events, contract validation, and failure owner are configured."
