schemaVersion: 1
kind: zj-loop-route-table

metadata:
  primary_pattern: "__PATTERN_ID__"
  primary_pattern_name: "__PATTERN_NAME__"
  generated_by: "zj-loop-init"

policy:
  description: "Routing policy for loop signals. This file is not a runtime queue."
  lifecycle_evidence:
    - "append-only issue or PR comments"
    - "consumer-owned state files"
    - "workflow runs"
    - "PRs"
  default_enablement:
    human: true
    ignore: true
    selected_pattern_report_only: true
    cross_component_dispatch: false
    side_effect_routes: false

routes:
  - route_id: "human"
    enabled: true
    request_kind: "report-only"
    consumer: "maintainer"
    consumer_kind: "human-gate"
    execution:
      mode: "report-only"
      side_effect_level: "evidence"
      completion_forms: ["human-decision"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["high-risk-review", "unknown-risk-review"]
      verifiers: ["human-review"]
      max_side_effect_level: "evidence"
    evidence_store: "__PATTERN_STATE__"
    match:
      risk: ["high", "unknown"]
    guards:
      requires_human_review: true
    dedupe_window: "24h"
    failure_owner: "maintainer"
    human_gate: "always"

  - route_id: "ignore"
    enabled: true
    request_kind: "report-only"
    consumer: "producer"
    consumer_kind: "producer-router"
    execution:
      mode: "report-only"
      side_effect_level: "evidence"
      completion_forms: ["report-evidence"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["noise-suppression", "route-decision"]
      verifiers: ["route-decision-evidence"]
      max_side_effect_level: "evidence"
    evidence_store: "__PATTERN_STATE__"
    match:
      route: ["ignore"]
    guards:
      requires_noise_reason: true
    dedupe_window: "24h"
    failure_owner: "producer"
    human_gate: "none"

  - route_id: "__PATTERN_ID__-report"
    enabled: true
    request_kind: "report-only"
    consumer: "__PATTERN_ID__"
    consumer_kind: "report-consumer"
    execution:
      mode: "report-only"
      side_effect_level: "evidence"
      completion_forms: ["report-evidence"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["__PATTERN_ID__", "route-decision"]
      verifiers: ["route-decision-evidence"]
      max_side_effect_level: "evidence"
    evidence_store: "__PATTERN_STATE__"
    match:
      route: ["__PATTERN_ID__"]
    guards:
      side_effects_allowed: false
    dedupe_window: "24h"
    failure_owner: "__PATTERN_ID__"
    human_gate: "on ambiguity or high risk"

  - route_id: "manual-smoke-report"
    enabled: true
    request_kind: "report-only"
    consumer: "manual-smoke"
    consumer_kind: "report-consumer"
    execution:
      mode: "report-only"
      side_effect_level: "evidence"
      completion_forms: ["report-evidence"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["manual-smoke", "generated-workflow"]
      verifiers: ["workflow-summary"]
      max_side_effect_level: "evidence"
    evidence_store: "GitHub Actions workflow summary"
    match:
      source: ["workflow-dispatch"]
      route: ["manual-smoke-report"]
    guards:
      side_effects_allowed: false
    dedupe_window: "workflow_run"
    failure_owner: "maintainer"
    human_gate: "none"

disabled_dispatch_routes:
  - route_id: "ci-sweeper"
    enabled: false
    request_kind: "issue-fix-request"
    consumer: "ci-sweeper"
    consumer_kind: "fix-runner"
    execution:
      mode: "request-only"
      side_effect_level: "request"
      completion_forms: ["repair-pr", "escalation-issue"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["ci", "generated-workflow"]
      verifiers: ["workflow-run", "gates", "diff-check"]
      max_side_effect_level: "request"
    evidence_store: "zj-loop/ci-sweeper-state.md"
    note: "Enable only after CI Sweeper workflow, budget, and failure owner are configured."

  - route_id: "pr-steward-report"
    enabled: false
    request_kind: "report-only"
    consumer: "pr-steward"
    consumer_kind: "report-consumer"
    execution:
      mode: "report-only"
      side_effect_level: "evidence"
      completion_forms: ["report-evidence"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["pull-request", "status-observation"]
      verifiers: ["route-decision-evidence", "forbidden-side-effect-check"]
      max_side_effect_level: "evidence"
    evidence_store: "zj-loop/pr-steward-state.md"
    guards:
      side_effects_allowed: false
      source_pr_comment_allowed: false
      label_changes_allowed: false
      rebase_allowed: false
      merge_allowed: false
    note: "PR Steward report route records PR event evidence only."

  - route_id: "pr-steward-fix-request"
    enabled: false
    request_kind: "issue-fix-request"
    consumer: "pr-steward"
    consumer_kind: "fix-runner"
    execution:
      mode: "claim-only"
      side_effect_level: "claim"
      completion_forms: ["repair-pr", "escalation-issue"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["pull-request", "failed-check-rollup"]
      verifiers: ["status-check-rollup", "request-claim"]
      max_side_effect_level: "claim"
    evidence_store: "GitHub issues"
    guards:
      independent_issue_carrier: true
      claim_only: true
      source_pr_comment_allowed_during_claim: false
      label_changes_allowed_during_claim: false
      rebase_allowed_during_claim: false
      merge_allowed_during_claim: false
      workflow_dispatch_allowed_during_claim: false
      repair_allowed_during_claim: false
      branch_creation_allowed_during_claim: false
      fix_pr_creation_allowed_during_claim: false
      fix_consumer_allowlist: ["pr-steward"]
    note: "Enable only after PR Steward fix-request carrier, claim policy, review boundaries, and evidence store are configured."

  - route_id: "issue-backlog-triage"
    enabled: false
    request_kind: "report-only"
    consumer: "issue-triage"
    consumer_kind: "report-consumer"
    execution:
      mode: "report-only"
      side_effect_level: "evidence"
      completion_forms: ["report-evidence"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["issue-backlog", "triage-observation"]
      verifiers: ["route-decision-evidence", "forbidden-side-effect-check"]
      max_side_effect_level: "evidence"
    evidence_store: "zj-loop/issue-triage-state.md"
    guards:
      side_effects_allowed: false
      public_issue_comment_allowed: false
      label_mutation_allowed: false
      close_reopen_allowed: false
      assignment_allowed: false
      milestone_allowed: false
      formal_issue_lifecycle_transition_allowed: false
      batch_mutation_allowed: false
    note: "Issue Backlog Triage route records issue observations only."

  - route_id: "issue-triage-action"
    enabled: false
    request_kind: "triage-action-request"
    consumer: "issue-triage-action"
    consumer_kind: "triage-action-consumer"
    execution:
      mode: "dry-run"
      side_effect_level: "label"
      completion_forms: ["triage-label-applied", "triage-comment-posted", "triage-action-skipped", "escalation-issue"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["issue-backlog", "triage-label", "fixed-triage-comment"]
      verifiers: ["allowlisted-triage-action", "forbidden-side-effect-check"]
      max_side_effect_level: "label"
    evidence_store: "zj-loop/issue-triage-state.md"
    guards:
      side_effects_allowed: false
      live_side_effects_allowed: false
      public_issue_comment_allowed: "fixed-template-only"
      label_mutation_allowed: "allowlist-only"
      close_reopen_allowed: false
      assignment_allowed: false
      milestone_allowed: false
      formal_issue_lifecycle_transition_allowed: false
      batch_mutation_allowed: false
    note: "Enable dry-run first; live issue mutation requires later explicit promotion and generated-bundle evidence."

  - route_id: "issue-triage-transition"
    enabled: false
    request_kind: "triage-transition-confirmation"
    consumer: "issue-triage-transition"
    consumer_kind: "triage-action-consumer"
    execution:
      mode: "request-only"
      side_effect_level: "request"
      completion_forms: ["triage-transition-confirmed", "issue-fix-request-created", "triage-action-skipped", "escalation-issue"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["issue-backlog", "triage-transition", "zj-triage-role"]
      verifiers: ["route-replay", "zj-triage-brief", "forbidden-side-effect-check"]
      max_side_effect_level: "request"
    evidence_store: "zj-loop/issue-triage-state.md"
    guards:
      side_effects_allowed: "request-carrier-only"
      live_side_effects_allowed: false
      actor_permission_required: "maintainer-or-collaborator"
      fixed_confirmation_phrase: "CONFIRM_TRIAGE_TRANSITION"
      public_issue_comment_allowed: false
      label_mutation_allowed: false
      close_reopen_allowed: false
      assignment_allowed: false
      milestone_allowed: false
      batch_mutation_allowed: false
      wontfix_default_confirmation_allowed: false
    note: "Enable when maintainers should confirm recommended triage transitions and create independent Issue Fix Request carriers for ready-for-agent recommendations."

  - route_id: "dependency-sweeper"
    enabled: false
    request_kind: "issue-fix-request"
    consumer: "dependency-sweeper"
    consumer_kind: "fix-runner"
    execution:
      mode: "request-only"
      side_effect_level: "request"
      completion_forms: ["repair-pr", "escalation-issue"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["dependency", "patch-update", "minor-update"]
      verifiers: ["package-risk-check", "verification-gate"]
      max_side_effect_level: "request"
    evidence_store: "zj-loop/dependency-sweeper-state.md"
    note: "Enable only after dependency risk policy and verifier gates are configured."

  - route_id: "changelog-drafter-report"
    enabled: false
    request_kind: "report-only"
    consumer: "changelog-drafter"
    consumer_kind: "draft-consumer"
    execution:
      mode: "report-only"
      side_effect_level: "evidence"
      completion_forms: ["draft-pr", "draft-evidence", "escalation-issue"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["release-prep", "merged-pr-batch", "changelog-observation"]
      verifiers: ["route-decision-evidence", "human-review-boundary"]
      max_side_effect_level: "evidence"
    evidence_store: "zj-loop/changelog-drafter-state.md"
    guards:
      side_effects_allowed: false
      release_notes_draft_allowed: false
      changelog_edit_allowed: false
      changelog_pr_allowed: false
      tag_allowed: false
      release_allowed: false
      package_publish_allowed: false
      workflow_dispatch_allowed: false
    note: "Changelog Drafter report route records release-window evidence only."

  - route_id: "changelog-drafter-draft-request"
    enabled: false
    request_kind: "draft-request"
    consumer: "changelog-drafter"
    consumer_kind: "draft-consumer"
    execution:
      mode: "dry-run"
      side_effect_level: "evidence"
      completion_forms: ["draft-pr", "draft-evidence", "escalation-issue"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["release-prep", "draft-request"]
      verifiers: ["existing-changelog-report", "dedupe-check"]
      max_side_effect_level: "evidence"
    evidence_store: "zj-loop/changelog-drafter-state.md"
    guards:
      side_effects_allowed: false
      requires_existing_changelog_report: true
      draft_consumer_start_allowed: false
      release_notes_draft_allowed: false
      changelog_edit_allowed: false
      changelog_pr_allowed: false
      tag_allowed: false
      release_allowed: false
      package_publish_allowed: false
      workflow_dispatch_allowed: false
    note: "Draft request evidence is separate from live changelog edits or release publishing."

  - route_id: "roadmap-sliced-development"
    enabled: false
    request_kind: "activation-comment"
    consumer: "roadmap-sliced-development"
    consumer_kind: "activation-consumer"
    execution:
      mode: "request-only"
      side_effect_level: "request"
      completion_forms: ["roadmap-branch-pr", "activation-failed", "activation-resumable"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["roadmap-activation", "roadmap-bootstrap"]
      verifiers: ["activation-comment", "resume-anchors", "roadmap-gates"]
      max_side_effect_level: "branch"
    evidence_store: "append-only GitHub issue comments"
    note: "Activation creates a request only; Roadmap-Sliced Development owns execution."

  - route_id: "post-merge-roadmap-closeout"
    enabled: false
    request_kind: "report-only"
    consumer: "post-merge-cleanup"
    mode: "roadmap-closeout"
    consumer_kind: "cleanup-consumer"
    execution:
      mode: "dry-run"
      side_effect_level: "issue-comment"
      completion_forms: ["cleanup-done", "cleanup-skipped", "escalation-issue"]
    maturity:
      protocol: "install-ready"
      runner: "install-ready"
    capabilities:
      scopes: ["roadmap-closeout", "merged-zjal-branch", "carrier-issue-closeout"]
      verifiers: ["post-merge-contract", "branch-prefix-allowlist", "fixed-confirmation-phrase"]
      max_side_effect_level: "cleanup"
    evidence_store: "GitHub pull request comment"
    guards:
      requires_post_merge_contract: true
      report_only_if_contract_missing: true
      requires_no_pending_followups: true
      destructive_actions_enabled: false
      branch_prefix_allowlist: ["zjal/"]
      close_carrier_issue_only: true
    note: "Enable only after merged-PR events, contract validation, and failure owner are configured."
