{
  "name": "@jununfly/zj-loop-audit",
  "version": "1.4.2",
  "description": "Agentic Loop Working readiness auditor. Compute Loop Readiness Score (L0-L3), detect activity, and get actionable suggestions. npx @jununfly/zj-loop-audit . --suggest",
  "type": "module",
  "bin": {
    "zj-loop-audit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "rules",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/auditor.test.mjs",
    "prepublishOnly": "npm test",
    "start": "node dist/cli.js",
    "audit": "npm run build && node dist/cli.js",
    "audit:suggest": "npm run build && node dist/cli.js . --suggest",
    "demo": "bash ../../scripts/before-after-demo.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zagenticloop",
    "ai-agents",
    "coding-agents",
    "claude-code",
    "codex",
    "grok",
    "readiness",
    "audit"
  ],
  "author": "Jununfly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jununfly/ZAgenticLoop.git",
    "directory": "tools/zj-loop-audit"
  },
  "homepage": "https://jununfly.github.io/ZAgenticLoop/",
  "bugs": {
    "url": "https://github.com/jununfly/ZAgenticLoop/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@jununfly/zj-loop-core": "file:../zj-loop-core",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
