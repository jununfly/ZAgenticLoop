{
  "name": "@jununfly/zj-loop-core",
  "version": "0.1.4",
  "description": "Shared Agentic Loop Working domain models and registry loading utilities.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "zj-loop-route": "./dist/route-cli.js",
    "zj-loop-consumer": "./dist/consumer-cli.js",
    "zj-loop-ci-sweeper": "./dist/ci-sweeper-cli.js",
    "zj-loop-roadmap-activation": "./dist/roadmap-activation-cli.js",
    "zj-loop-pr-steward": "./dist/pr-steward-cli.js",
    "zj-loop-dependency-sweeper": "./dist/dependency-sweeper-cli.js",
    "zj-loop-changelog-drafter": "./dist/changelog-drafter-cli.js",
    "zj-loop-issue-triage-action": "./dist/issue-triage-action-cli.js",
    "zj-loop-issue-triage-transition": "./dist/issue-triage-transition-cli.js",
    "zj-loop-post-merge-closeout": "./dist/post-merge-closeout-cli.js",
    "zj-loop-prd-handoff": "./dist/prd-handoff-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/registry.test.mjs test/project.test.mjs test/semantic.test.mjs test/cli.test.mjs test/route.test.mjs test/consumer-runner.test.mjs test/live-runner-contract.test.mjs test/ci-sweeper-runner.test.mjs test/post-merge-closeout-runner.test.mjs test/dependency-sweeper-runner.test.mjs test/pr-steward-runner.test.mjs test/changelog-drafter-runner.test.mjs test/issue-triage-action-runner.test.mjs test/issue-triage-transition-runner.test.mjs test/roadmap-activation-runner.test.mjs test/prd-handoff-runner.test.mjs",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zagenticloop",
    "agentic-loop-working",
    "registry",
    "coding-agents"
  ],
  "author": "Jununfly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jununfly/ZAgenticLoop.git",
    "directory": "tools/zj-loop-core"
  },
  "homepage": "https://jununfly.github.io/ZAgenticLoop/",
  "bugs": {
    "url": "https://github.com/jununfly/ZAgenticLoop/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "yaml": "^2.8.0",
    "zod": "^3.25 || ^4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
