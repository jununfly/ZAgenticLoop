{
  "name": "@jununfly/zj-loop-cost",
  "version": "0.1.5",
  "description": "Estimate token budgets and daily costs for agentic loop working patterns. By cadence, readiness level (L1/L2/L3), and coding agent tool.",
  "type": "module",
  "bin": {
    "zj-loop-cost": "dist/cli.js"
  },
  "files": [
    "dist",
    "registry.json",
    "README.md"
  ],
  "scripts": {
    "bundle": "node scripts/bundle-registry.mjs",
    "build": "npm run bundle && tsc && chmod +x dist/cli.js",
    "test": "npm run build && node --test test/estimator.test.mjs test/cli.test.mjs",
    "prepublishOnly": "npm test",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zagenticloop",
    "ai-agents",
    "coding-agents",
    "token-budget",
    "cost-estimate",
    "claude-code",
    "grok",
    "budget",
    "devtools"
  ],
  "author": "Jununfly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jununfly/ZAgenticLoop.git",
    "directory": "tools/zj-loop-cost"
  },
  "homepage": "https://jununfly.github.io/ZAgenticLoop/",
  "bugs": {
    "url": "https://github.com/jununfly/ZAgenticLoop/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@jununfly/zj-loop-core": "^0.1.2",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
