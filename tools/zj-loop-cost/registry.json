        "zj-rebase-and-clean"
      ],
      "state": "zj-loop/pr-steward-state.md",
      "phases": [
        "discover",
        "triage",
        "fix",
        "verify",
        "notify"
      ],
      "human_gates": [
        "security",
        "payments",
        "auth",
        "max-fix-attempts"
      ],
      "starter": "starters/pr-steward",
      "week_one_mode": "L1",
      "token_cost": "high",
      "cost": {
        "tokens_noop": 3000,
        "tokens_report": 80000,
        "tokens_action": 250000,
        "suggested_daily_cap": 2000000,
        "early_exit_required": true
      },
      "init": {
        "templates": {
          "minimal_fix": true,
          "verifier": false
        },
        "budget": {
          "max_runs_per_day": 288,
          "max_spawns_l1": 0,
          "max_spawns_l2": 3
        },
        "first_loop_command": {
          "grok": "/loop 10m Run zj-pr-review-triage. Update pr-steward-state.md. Worktree + zj-minimal-fix + verifier for allowlisted PRs only. Escalate after 3 attempts.",
          "claude": "/loop 10m $zj-pr-review-triage — update pr-steward-state.md. No auto-merge.",
          "codex": "Automation 10m: zj-pr-review-triage → pr-steward-state.md. No auto-merge."
        }
      }
