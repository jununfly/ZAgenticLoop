    {
      "id": "pr-steward",
      "name": "PR Steward",
      "file": "pr-steward.md",
      "goal": "Steward PRs through review, CI, rebase, and merge",
      "cadence": "5m-15m",
      "risk": "medium",
      "tools": [
        "grok",
        "claude-code",
        "codex",
        "github-actions"
      ],
      "skills": [
        "zj-pr-review-triage",
