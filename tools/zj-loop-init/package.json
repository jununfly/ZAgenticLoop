{
  "name": "@jununfly/zj-loop-init",
  "version": "0.1.6",
  "description": "Scaffold agentic loop working patterns and starters into any project. Supports Grok, Claude Code, Codex and more. npx @jununfly/zj-loop-init . --pattern daily-triage --tool grok",
  "type": "module",
  "bin": {
    "zj-loop-init": "./dist/cli.js"
  },
  "files": [
    "dist",
    "starters",
    "templates",
    "registry.yaml",
    "README.md"
  ],
  "scripts": {
    "bundle": "node scripts/bundle-assets.mjs",
    "build": "npm run bundle && tsc",
    "test": "npm run build && node --test test/cli.test.mjs",
    "prepublishOnly": "npm test",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zagenticloop",
    "ai-agents",
    "coding-agents",
    "scaffold",
    "starter",
    "claude-code",
    "grok",
    "codex",
    "github-actions",
    "patterns"
  ],
  "author": "Jununfly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jununfly/ZAgenticLoop.git",
    "directory": "tools/zj-loop-init"
  },
  "homepage": "https://jununfly.github.io/ZAgenticLoop/",
  "bugs": {
    "url": "https://github.com/jununfly/ZAgenticLoop/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@jununfly/zj-loop-core": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
